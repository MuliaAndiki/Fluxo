{
  "name": "my-productivity",
  "private": true,
  "packageManager": "pnpm@8.10.0",
  "devDependencies": {
    "turbo": "^2.6.3"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "pnpm --filter mobile dev",
    "build": "turbo run build",
    "dev:be": "turbo run dev --filter=backend"
  }
}
